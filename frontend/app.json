{
  "expo": {
    "name": "Météo Régionale",
    "slug": "meteo-regionale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meteo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghostchat.meteo",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour partager des photos météo",
        "NSPhotoLibraryUsageDescription": "Pour sauvegarder les images météo",
        "NSFaceIDUsageDescription": "Pour sécuriser vos préférences météo"
      }
    },
    "android": {
      "package": "com.ghostchat.meteo",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1e88e5"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Autoriser l'accès à la caméra pour scanner les QR codes"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser l'accès aux photos pour partager des images"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6f87bebf-351a-45d8-98da-a03dbd6375b3"
      },
      "backendUrl": "https://ghost-messenger.onrender.com"
    },
    "owner": "mad_deep888",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
